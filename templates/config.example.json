{
  "project": "my-app",
  "baseUrl": "http://localhost:3000",
  "storybookUrl": "http://localhost:6006",
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 900 },
    { "name": "tablet", "width": 768, "height": 1024 },
    { "name": "mobile", "width": 375, "height": 812 }
  ],
  "routes": [
    "/",
    "/dashboard",
    "/settings"
  ],
  "maskSelectors": [
    "[data-vr-mask]",
    ".live-timestamp",
    ".user-avatar"
  ],
  "engine": {
    "local": {
      "model": "claude"
    },
    "ci": {
      "model": "gemini-3.1-pro-preview",
      "apiKeyEnv": "GOOGLE_GENAI_API_KEY"
    }
  },
  "auth": {
    "storageState": ".dojowatch/auth.json",
    "profiles": {
      "admin": "e2e/.auth/admin.json",
      "student": "e2e/.auth/student.json"
    },
    "routes": {
      "/": null,
      "/dashboard": "student",
      "/admin": "admin"
    }
  },
  "smart": {
    "retries": 2,
    "readiness": {
      "waitForSelector": "[data-app-ready]",
      "timeout": 10000
    },
    "routeReadiness": {
      "/dashboard": { "waitForSelector": ".dashboard-loaded", "timeout": 15000 }
    },
    "detectBotProtection": true,
    "detectDynamicContent": false
  },
  "prefilter": {
    "threshold": 0.05,
    "clusterMinPixels": 500
  },
  "supabase": {
    "url": "https://your-project.supabase.co",
    "anonKey": "eyJhb...your-anon-key-here",
    "serviceKeyEnv": "SUPABASE_SERVICE_KEY",
    "signedUrlExpiry": 3600
  }
}
